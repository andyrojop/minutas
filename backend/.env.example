PORT=3001
# Con true: administradores necesitan JWT con MFA (aal2). Sin definir o false: acceso solo con contraseña hasta activar TOTP en Supabase.
# ADMIN_REQUIRE_AAL2=true

SUPABASE_URL=https://xxxx.supabase.co
# Clave anon (JWT eyJ…) o Publishable Key (sb_publishable_…). El API valida el Bearer con auth.getUser().
SUPABASE_ANON_KEY=
# Recomendada: service_role en Supabase. Alta de usuarios por administrador (POST /api/users) y sincronía RLS (005/006).
# Sin clave, el endpoint de invitación falla. Nunca en frontend ni en NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
FRONTEND_ORIGIN=http://localhost:3000

#Database URL - local
# If you are using in a server, you need to change the url to the server url
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
