{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsc-watch -p tsconfig.build.json --onSuccess \"node dist/main.js\"",
    "start:prod": "node dist/main.js",
    "migration:generate": "node ./database/scripts/generate-migration.js",
    "migration:create": "typeorm-ts-node-commonjs migration:create -d ./database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d ./database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d ./database/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d ./database/data-source.ts",
    "seed:run": "typeorm-ts-node-commonjs migration:run -d ./database/seed-data-source.ts",
    "seed:revert": "typeorm-ts-node-commonjs migration:revert -d ./database/seed-data-source.ts",
    "seed:show": "typeorm-ts-node-commonjs migration:show -d ./database/seed-data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.11",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.11",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "@supabase/supabase-js": "^2.105.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.4.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.29"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.3",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.9.3"
  }
}
