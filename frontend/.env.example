# Copia este archivo a `frontend/.env.local`.

# Con true: admins deben completar TOTP (JWT aal2). Omitir o false hasta tener MFA activo en Supabase.
# ADMIN_REQUIRE_AAL2=true

# Con true: desactiva /register y el enlace «Registrarse» en login (solo cuentas creadas por admin).
# NEXT_PUBLIC_INVITE_ONLY=true

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Clave anónima (JWT) o clave "publishable" según tu dashboard:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Si usas el nombre alternativo del dashboard:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# API NestJS (necesario para listados y acciones). Con backend apagado verás error de conexión.
# En desarrollo puedes usar en la raíz del repo: npm run dev:all
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Pad de firma Topaz (SigWeb, solo Windows con servicio SigWeb instalado) ---
# 1) Instala SigWeb desde Topaz y deja el servicio en ejecución.
# 2) Copia SigWebTablet.js del SDK a frontend/public/sigweb/ (ya hay .gitkeep en esa carpeta).
# 3) Descomenta la URL del script (ruta relativa al sitio; la app la convierte en absoluta en el navegador):
# NEXT_PUBLIC_TOPAZ_SIGWEB_SCRIPT_URL=/sigweb/SigWebTablet.js
# 4) Ajusta el puerto COM del pad (si defines nombre y número, gana el nombre):
# NEXT_PUBLIC_TOPAZ_COM_PORT=9
# NEXT_PUBLIC_TOPAZ_COM_NAME=COM3

# Opcional (SSR): sobrescribe la URL del backend solo en el servidor
# API_URL=http://localhost:3001


#NEXTAUTH_URL=http://localhost:3000
#NEXTAUTH_SECRET=fdaflkjadf12lkadf12lka